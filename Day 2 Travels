1.Create a table name as Travels with whatever the details needed (Apply constraints)

create table Traveln(
 car_no tinyint unique,
 car_name varchar(20) not null,
 car_price int check (car_price > 100),
 car_status varchar(50) default "no"
 );
 
 select*from Traveln;
 insert into Traveln(car_price)values(150);
 insert into Traveln(car_no,car_name)values(36,"kia");

2.Insert values into the Travels table and then add / change a column

 create table Traveli(
 car_no tinyint ,
 car_name varchar(20),
 car_price int
 );
 
 select*from Traveli;
 
 insert into Traveli(car_no,car_name,car_price)values(1,"kia",10000);
 insert into Traveli(car_no,car_name,car_price)values(2,"toyota",20000);
 
 alter table Traveli add column car_sizes varchar(50);
 update  Traveli set car_sizes ="confirm" where car_no =1;
  update  Traveli set car_sizes ="small" where car_no =2;
  alter table Traveli  rename column car_size to car_qty;
